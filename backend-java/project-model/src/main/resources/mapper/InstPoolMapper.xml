<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.zenith.admin.mapper.InstPoolMapper">

    <select id="selectPageByNameTypeStatus" resultType="com.zenith.admin.dataobject.InstPoolDO">
        SELECT *
        FROM t_inst_pool
        <where>
            <if test="name != null and name != ''">
                AND name ILIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="poolType != null and poolType != ''">
                AND pool_type = #{poolType}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY created_time DESC
    </select>

</mapper>
