<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zenith.admin.mapper.NodeTemplateMapper">

    <select id="selectByProcessTemplateId" resultType="com.zenith.admin.dataobject.NodeTemplateDO">
        SELECT * FROM t_wf_node_template 
        WHERE process_template_id = #{processTemplateId} 
        ORDER BY node_order ASC
    </select>

    <delete id="deleteByProcessTemplateId">
        DELETE FROM t_wf_node_template WHERE process_template_id = #{processTemplateId}
    </delete>

</mapper>
