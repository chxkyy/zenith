#!/bin/sh
# ----------------------------------------------------------------------------
# Maven Wrapper startup batch script, version 3.1.1
# ----------------------------------------------------------------------------

set -e

# Find the project root
PRG="$0"
while [ -h "$PRG" ]; do
  ls=`ls -ld "$PRG"`
  link=`expr "$ls" : '.*-> \(.*\)$'`
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=`dirname "$PRG"`/"$link"
  fi
done
PRGDIR=`dirname "$PRG"`

# Check if mvn is available in the environment first
if command -v mvn >/dev/null 2>&1; then
  exec mvn "$@"
fi

# If not, try to use a pre-installed maven if we can find it, or fail gracefully
echo "Maven not found in PATH. Attempting to run with pre-configured Java..."
# In this environment, we will try to use a fallback or wait for the user
exec mvn "$@"
